{ "name": "evm-contracts-tools",
  "version":
    "0.0.36",
  "description":
    "JavaScript programs and libraries to enable seamless development of native computer applications designed to interact with Ethereum Virtual Machine-compatible networks.",
  "funding": {
    "type":
      "patreon",
    "url":
      "https://patreon.com/tallero"
  },
  "man": [
    "./man/ethereum-address-validate.1",
    "./man/evm-contract-bytecode-get.1",
    "./man/evm-contract-deployer-get.1",
    "./man/evm-contract-deployment-address.1",
    "./man/evm-contract-deployments-dir.1",
    "./man/evm-contract-call.1",
    "./man/evm-contract-call-dynamic.1"
  ],
  "files": [
    "AUTHORS.rst",
    "COPYING",
    "Makefile",
    "README.md",
    "dist",
    "evm-contract-call",
    "evm-contract-call.webpack.config.js",
    "evm-contract-deployments-dir",
    "evm-contract-deployments-dir.webpack.config.js",
    "fs-worker.webpack.config.js",
    "index.html",
    "libevm-contract-call",
    "libevm-contract-call.webpack.config.js",
    "libevm-contract-deployments-dir",
    "libevm-contract-deployments-dir.webpack.config.js",
    "lib",
    "evm-contracts-tools",
    "package.json",
    "serve.json",
    "webpack.config.js"
  ],
  "keywords": [
    "ur",
    "themartiancompany",
    "dogeos",
    "ethereum",
    "evmfs",
    "libevm",
    "evm-toolchain"
  ],
  "homepage":
    "https://github.com/themartiancompany/evm-contracts-tools",
  "bugs": {
    "url":
      "https://github.com/themartiancompany/evm-contracts-tools.js/issues"
  },
  "repository": {
    "type":
      "git",
    "url":
      "git+https://github.com/themartiancompany/evm-contracts-tools.js.git"
  },
  "license":
    "AGPL-3.0-or-later",
  "author": {
    "name":
      "Pellegrino Prevete",
    "email":
      "pellegrinoprevete@gmail.com",
    "url":
      "https://github.com/tallero"
  },
  "devDependencies": {
    "crash-js-webpack":
      "^0.0.28",
    "flatted":
      "^3.2.9",
    "eslint":
      "^10.0.3",
    "globals":
      "^17.3.0",
    "@eslint/js":
      "^10.0.1",
    "safely-serve":
      "^0.0.9",
    "webpack":
      "^5.102.1",
    "webpack-cli":
      "^6.0.1"
  },
  "dependencies": {
    "crash-js":
      "^0.1.134",
    "ethers":
      "^6.13.2",
    "evm-chains-info":
      "^0.0.22",
    "evm-transactions-tools":
      "^0.0.9",
    "evm-wallet.js":
      "^0.0.50",
    "libevm":
      "^0.0.27",
    "yargs":
      "18.0.0"
  },
  "overrides": {
    "evm-contracts-tools":
      "^0.0.32",
    "evm-wallet.js":
      "^0.0.50"
  },
  "type":
    "commonjs",
  "main":
    "evm-contracts-tools",
  "bin":
    { 
      "ethereum-address-validate":
        "lib/address-check",
      "evm-contract-call":
        "evm-contract-call",
      "evm-contract-call.js":
        "evm-contract-call",
      "evm-contract-call-dynamic.js":
        "lib/evm-contract-call-dynamic",
      "evm-contract-deployments-dir.js":
        "evm-contract-deployments-dir",
      "evm-contract-deployments-dir":
        "evm-contract-deployments-dir",
      "evm-contract-call-static.js":
        "lib/evm-contract-call-static" },
  "scripts": {
    "build-fs-worker":
      "npx webpack --mode 'production' --config 'fs-worker.webpack.config.cjs' --stats-error-details && cp 'fs-worker.js' 'dist/'{'evm-contract-call','evm-contracts-tools','libevm-contract-call'}",
    "build-libevm-contract-call":
      "npx webpack --mode 'production' --config 'libevm-contract-call.webpack.config.cjs' --stats-error-details && mv 'libevm-contract-call.js' 'dist/libevm-contract-call'",
    "build-libevm-contract-deployments-dir":
      "npx webpack --mode 'production' --config 'libevm-contract-deployments-dir.webpack.config.cjs' --stats-error-details && mv 'libevm-contract-deployments-dir.js' 'dist/libevm-contract-deployments-dir'",
    "build-lib":
      "npm run build-libevm-contract-call && npm run build-libevm-contract-deployments-dir",
    "build-evm-contract-call":
      "npx webpack --mode 'production' --config 'evm-contract-call.webpack.config.cjs' --stats-error-details && mv 'evm-contract-call.js' 'dist/evm-contract-call'",
    "build-evm-contracts-tools":
      "npx webpack --mode 'production' --config 'webpack.config.cjs' --stats-error-details && mv 'evm-contracts-tools.js' 'dist/evm-contracts-tools'",
    "build-evm-contract-deployments-dir":
      "npx webpack --mode 'production' --config 'evm-contract-deployments-dir.webpack.config.cjs' --stats-error-details && mv 'evm-contract-deployments-dir.js' 'dist/evm-contract-deployments-dir' && npx webpack --mode 'production' --config 'webpack.config.cjs' --stats-error-details && mv 'evm-contracts-tools.js' 'dist/evm-contracts-tools'",
    "build-bin":
      "npm run build-evm-contract-call && npm run build-evm-contract-deployments-dir && npm run build-evm-contracts-tools",
    "build-man":
      "make build-man",
    "build":
      "npm run lint && npm run build-fs-worker && npm run build-lib && npm run build-bin",
    "lint":
      "npx eslint .",
    "publish-npm":
      "npm run build-man && npm run build && npm publish --access public",
    "start":
      "npx safely-serve --help # index.html --port 3000 --https --no-cache",
    "test":
      "echo \"Error: no test specified\" && exit 1"
  }
}
