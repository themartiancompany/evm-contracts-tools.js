async function 
  _cmdline_parse() {
  let
    _help_display,
    _msg;
  const
    _argv_args = {
      "booleans": [
        "a",
        "auth",
        "h",
        "help",
        "I",
        "index-retrieve",
        "v",
        "verbose"
      ]
    };
  const
    _argv =
      _argv_get(
        _argv_args);
  const
    _options =
      _argv[
        "_"];
  quiet = 
    "y";
  runtime_environment =
    "node";
  if ( _argv["h"] == true ) {
    _help_display =
      true;
  }
  if ( _argv["help"] == true ) {
    _help_display =
      true;
  }
  if ( ( _options.indexOf(
           "--help") > -1 ||
         _options.indexOf(
           "-h") > -1) ) {
    _help_display =
      true;
  }
  if ( _help_display ) {
    quiet =
      "n";
    await _overrides_set();
    _usage(
      0);
  }
  if ( typeof(
         _argv) == "undefined" ||
       _argv[
         "_"].length < 1 ) {
    _msg =
      "Contract address argument required.";
    _msg_error(
      _msg,
      0);
    _usage(
      1);
  }
  contract_address =
    _argv[
      "_"][
        0];
  if ( typeof(
         _argv) == "undefined" ||
       _argv[
         "_"].length < 2 ) {
    _msg =
      "Contract method argument required.";
    _msg_error(
      _msg,
      0);
    _usage(
      1);
  }
  contract_method =
    _argv[
      "_"][
        0];
  const
    method_args =
      _argv[
        "_"].slice(
        2,
        _argv[
          "_"].length - 2);
  if ( "t" in _argv ) {
    call_type =
      _argv[
        "t"];
  }
  if ( "call-type" in _argv ) {
    call_type =
      _argv[
        "call-type"];
  }
  if ( "T" in _argv ) {
    call_timeout =
      _argv[
        "t"];
  }
  if ( "call-timeout" in _argv ) {
    call_timeout =
      _argv[
        "call-timeout"];
  }
  if ( "I" in _argv ) {
    index_retrieve =
      _argv[
        "I"];
  }
  if ( "index_retrieve" in _argv ) {
    index_retrieve =
      _argv[
        "index-retrieve"];
  }
  if ( "P" in _argv ) {
    price_gas =
      _argv[
        "P"];
  }
  if ( "price-gas" in _argv ) {
    price_gas =
      _argv[
        "price-gas"];
  }
  if ( "u" in _argv ) {
    measure_unit =
      _argv[
        "u"];
  }
  if ( "measure-unit" in _argv ) {
    measure_unit =
      _argv[
        "measure-unit"];
  }
  if ( "V" in _argv ) {
    msg_value =
      _argv[
        "V"];
  }
  if ( "msg-value" in _argv ) {
    msg_value =
      _argv[
        "msg-value"];
  }
  if ( "r" in _argv ) {
    retries_max =
      _argv[
        "r"];
  }
  if ( "retries-max" in _argv ) {
    retries_max =
      _argv[
        "retries-max"];
  }
  if ( "S" in _argv ) {
    rpc_selection =
      _argv[
        "S"];
  }
  if ( "rpc-selection" in _argv ) {
    rpc_selection =
      _argv[
        "rpc-selection"];
  }
  if ( "A" in _argv ) {
    contract_abi =
      _argv[
        "A"];
  }
  if ( "abi" in _argv ) {
    contract_abi =
      _argv[
        "abi"];
  }
  if ( "B" in _argv ) {
    contract_bytecode =
      _argv[
        "B"];
  }
  if ( "bytecode" in _argv ) {
    contract_bytecode =
      _argv[
        "bytecode"];
  }
  if ( "C" in _argv ) {
    contract_compiler_output =
      _argv[
        "C"];
  }
  if ( "compiler-output" in _argv ) {
    contract_compiler_output =
      _argv[
        "compiler-output"];
  }
  if ( "a" in _argv ) {
    call_auth =
      "y";
  }
  if ( "auth" in _argv ) {
    call_auth =
      "y";
  }
  if ( "n" in _argv ) {
    target_networks.push(
      _argv[
        "n"]);
  }
  if ( "network" in _argv ) {
    target_networks.push(
      _argv[
        "network"]);
  }
  _libevm_cmdline_parse(
    _argv);
  if ( _argv[
         "v"] ||
       _argv[
         "verbose"] ) {
    quiet =
      "n";
  }
}

function
  _url_parse() {
  let
    _method,
    _network;
  runtime_environment =
    "browser";
  call_type =
    _argv_url_get(
      "call_type")[
        0];
  call_timeout =
    _argv_url_get(
      "call_timeout")[
        0];
  index_retrieve =
    _argv_url_get(
      "index_retrieve")[
        0];
  price_gas =
    _argv_url_get(
      "price_gas")[
        0];
  measure_unit =
    _argv_url_get(
      "measure_unit")[
        0];
  msg_value =
    _argv_url_get(
      "msg_value")[
        0];
  retries_max =
    _argv_url_get(
      "retries_max")[
        0];
  rpc_selection =
    _argv_url_get(
      "rpc_selection")[
        0];
  contract_abi =
    _argv_url_get(
      "abi")[
        0];
  contract_bytecode =
    _argv_url_get(
      "bytecode")[
        0];
  contract_compiler_output =
    _argv_url_get(
      "compiler_output")[
        0];
  rpc_selection =
    _argv_url_get(
      "rpc_selection")[
        0];
  for ( _network of _argv_url_get(
                     "network") ) {
    target_networks.push(
      _network);
  }
  for ( _method of _argv_url_get(
                     "method_args") ) {
    method_args.push(
      _method);
  }
  quiet =
    _argv_url_get(
      "quiet");
  if ( quiet.length === 0 ) {
    quiet =
      "n";
  }
}

async function
  _evm_contract_deployments_dir_cmdline(
    _app_opts) {
  let
    _result;
  const
    _results =
      await _evm_contract_deployments_dir.apply(
        null,
        app_opts);
  const
    _results_type =
      typeof(
        _results);
  if ( _results_type == "object" ) {
    for ( _result of _results ) {
      console.log(
        _result);
    }
  }
  else if ( _results_type == "string" ) {
    _printf(
      _results);
  }
}

async function
  _main() {
  const
    _overrides_set_up =
      await _overrides_set();
  _config_show();
  app_opts = [
    target_app,
    user_level
  ];
  await _evm_contract_deployments_dir(
    app_opts);
}

_global_variables();
_libevm_global_variables();
if ( _cmdline_check(
       "evm-contract-deployments-dir.js") == true ||
     _cmdline_check(
       "evm-contract-deployments-dir") == true ) {
  _cmdline_parse();
}
else{
  _url_parse();
  _libevm_url_parse();
}
_main();
