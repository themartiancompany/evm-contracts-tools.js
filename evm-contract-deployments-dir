async function 
  _overrides_set() {
  const
    _address_valid =
      _address_check(
        contract_address);
  if ( ! _address_valid ) {
    const
      _msg =
        "Contract address " +
        `'${contract_address}' is ` +
        `invalid.`;
    _msg_error(
      _msg,
      1);
  }
  if ( call_date == "" ||
       typeof(
         call_date) == "undefined" ) {
    call_date =
      _get_date_human();
  }
  if ( wallet_name == "" ) {
    wallet_name =
      "default";
  }
  if ( index_retrieve == "" ) {
    index_retrieve =
      "n";
  }
  if ( retries_max == "" ) {
    retries_max =
      "300";
  }
  if ( rpc_selection == "" ) {
    rpc_selection =
      "kirsh";
  }
  if ( call_type == "" ) {
    call_type =
      "static";
  }
  _call_auth_auto_detect();
  if ( call_timeout == "" ) {
    call_timeout =
      "300000";
  }
  if ( measure_unit == "" ) {
    measure_unit =
      "ether";
  }
  if ( msg_value == "" ) {
    msg_value =
      "0";
  }
  // _api_key_auto_detect();
  if ( contract_address != "" ) {
    if ( contract_abi == "" ) {
      contract_abi =
        _default_artifact_path_get(
          "abi");
      _artifact_local_auto_detect(
        "bytecode");
      _artifact_local_auto_detect(
        "compiler_output");
      if ( contract_abi == "" ||
           _default_artifact_path_get(
             "abi") == contract_abi ) {
        _contract_abi_auto_detect();
      }
    }
  }
  await _wallet_overrides_set(
    "evm-wallet",
    wallet_name,
    call_auth);
}

